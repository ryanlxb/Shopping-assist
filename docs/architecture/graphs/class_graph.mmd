    class JDScraper {
        -__init__(headless)
        -_ensure_browser()
        -_new_context()
        -_random_delay(min_s, max_s)
        -_save_cookies(context)
        +search(keyword, limit)
        +get_detail(product_url)
        +download_images(image_urls, product_id)
        +close()
    }
